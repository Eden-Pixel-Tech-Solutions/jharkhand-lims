{
  "name": "meril-lims",
  "version": "1.0.0",
  "description": "Meril LIMS",
  "main": "main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"vite --config renderer/vite.config.js\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "build:ui": "vite build --config renderer/vite.config.js",
    "dist:win": "npm run build:ui && electron-builder --win",
    "dist:mac": "npm run build:ui && electron-builder --mac"
  },
  "build": {
    "appId": "com.poxiatechnologies.merillims",
    "productName": "Meril LIMS",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"],
      "icon": "renderer/src/assets/img/meril.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "renderer/src/assets/img/meril.png"
    },
    "files": [
      "main/**/*",
      "dist/**/*",
      "package.json",
      "renderer/src/assets/img/meril.png"
    ]
  },
  "dependencies": {
    "axios": "^1.16.0",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.28.0",
    "serialport": "^13.0.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
