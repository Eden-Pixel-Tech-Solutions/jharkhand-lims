*.postman_collection
*.postman_environment

# Integration spec docs with embedded live credentials
CARE_HMIS.md

# Build outputs
dist/
build/
out/
.next/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# LIS Agent specifics — matches the actual runtime filenames (underscore/.db
# under db/, hyphen/.sqlite at the project root), unlike the old pattern which
# matched neither and left both tracked in git.
/LIS-Agent/db/lis_agent.db
/LIS-Agent/db/*.db-journal
/LIS-Agent/lis-agent.sqlite

# WhatsApp Bot specifics
/WhatsApp-chat-bot/.wwebjs_auth/
/WhatsApp-chat-bot/.wwebjs_cache/
/WhatsApp-chat-bot/session.json
/WhatsApp-chat-bot/auth_info.json

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/

# Tender scraper runtime output
putty-test/captcha_solver/Scrapper/tender_documents/
putty-test/captcha_solver/Scrapper/row_data_cppp_states_diagno.csv

# Stray venv left outside the standard venv/.venv names above
py/venv311/

# Claude Code local tool config — not application code
.claude/

# Confidential third-party security audit deliverables — the VAPT report
# itself restricts distribution to its named recipient list, so these must
# never land in version control (repo access != authorized recipient).
VAPT.pdf
Acunetix Report.pdf
Burp Report.html
Zap Report.html
JH-LIMS-VAPT.zip
JH-LIMS-VAPT/

# Unrelated large/binary artifacts that don't belong in source control
customerApp/
LIS-Agent.zip
app-release.apk
GeM-Bidding-9559616.pdf

# Electron build output (electron-builder release artifacts — large binaries).
# Restoring this rule: it was dropped from .gitignore at some point, which
# would otherwise let 337MB of Chromium license/binary output back into git.
/LIS-Agent/release/

# Android generated build output (gradle build/, native .cxx/, local SDK
# path config) — android/app/build/ alone runs ~2.7GB and is fully
# reproducible from android/app/src/, so it must never be committed.
SampleCollector-App/android/app/build/
SampleCollector-App/android/app/.cxx/
SampleCollector-App/android/build/
SampleCollector-App/android/.gradle/
SampleCollector-App/android/local.properties